package generic

type floats interface {
	bfloat16 | float32 | float64
}

func genericCast[T floats](x [2]float32) [2]T {
	return [2]T(x)
}

func TestGenericCast() [2]float64 {
	return genericCast[float64]([2]float32{1, 2})
	// Want:
	// [2]float64{1, 2}
}

func callGenericCast[T floats](x [2]float32) [2]T {
	return genericCast[T](x)
}

func TestGenericCallGenericCast() [2]float64 {
	return callGenericCast[float64]([2]float32{1, 2})
	// Want:
	// [2]float64{1, 2}
}

func newFloat32[shape []int]() [unpack(shape)]float32 {
	return [unpack(shape)]float32{}
}

func genericNewFloat32[T floats, shape []int]() [unpack(shape)]T {
	return [unpack(shape)]T(newFloat32[shape]())
}

func TestGenericCastWithGenericShape() [2][3]float64 {
	return genericNewFloat32[float64][[]int{2, 3}]()
	// Want:
	// [2][3]float64{
	// 	{0, 0, 0},
	// 	{0, 0, 0},
	// }
}

func newFloat32G[X int]() [X]float32 {
	return [X]float32{}
}

func TestGenericAxLen() [2]float32 {
	return newFloat32G[2]()
	// Want:
	// [2]float32{0, 0}
}
