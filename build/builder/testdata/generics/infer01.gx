package infer01

type ints interface {
	int32 | int64
}

type floats interface {
	float32 | float64
}

func toFloats[Dest floats, Src ints, Shape []int](a Src) Dest {
	return Dest(a)
}

func TestCast() float32 {
	a := [2][3]int64{{1, 2, 3}, {4, 5, 6}}
	f32a := toFloats[float32, int64](a) // ERROR in call to toFloats, cannot infer type Shape
	return f32a
}
