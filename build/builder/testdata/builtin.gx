package builtin

func newForLen() [2][1]float32 {
	return [2][1]float32{{1}, {2}}
}

func TestLen2() int64 {
	return len(newForLen())
	// Want:
	// int64(2)
}

func TestLen3() float32 {
	return float32(len(newForLen()))
	// Want:
	// float32(2)
}

func LenUnknownRank(x [_ax]float32) int64 {
	return len(x)
}

func TestLen1a() int64 {
	return len([3]float32{1, 2, 3})
	// Want:
	// int64(3)
}

func TestLen1b() int64 {
	return len([...]float32{1, 2, 3})
	// Want:
	// int64(3)
}

func TestLen1c() int64 {
	return LenUnknownRank([...]float32{1, 2, 3})
	// Want:
	// int64(3)
}

func TestLen2a() int64 {
	return len([2][3]float32{{1, 2, 3}, {4, 5, 6}})
	// Want:
	// int64(2)
}

func TestLen2b() int64 {
	return len([...]float32{{1, 2, 3}, {4, 5, 6}})
	// Want:
	// int64(2)
}

func TestLen3b() int64 {
	return LenUnknownRank([...]float32{1, 2, 3, 4, 5, 6})
	// Want:
	// int64(6)
}
