package stdlib

import (
	"control"
	"math"
	"num"
	"rand"
	"shape"
)

func testMatmul1Axis() float32 {
	a := [2]float32{}
	b := [3]float32{}
	return num.MatMul(a, b) // ERROR left argument (shape: [2]) not compatible with right argument (shape: [3]) in MatMul call
}

func testMatmul2Axis() float32 {
	a := [2][4]float32{}
	b := [3]float32{}
	return num.MatMul(a, b) // ERROR left argument (shape: [2][4]) not compatible with right argument (shape: [3]) in MatMul call
}

func testMatmulLeftMoreThan2Axis() float32 {
	a := [3][2][4]float32{}
	b := [4][3]float32{}
	return num.MatMul(a, b) // ERROR more than 2-axis for the left argument (shape: [3][2][4]) not supported in MatMul call
}

func testMatmulRightMoreThan2Axis() float32 {
	a := [4][3]float32{}
	b := [3][2][4]float32{}
	return num.MatMul(a, b) // ERROR more than 2-axis for the right argument (shape: [3][2][4]) not supported in MatMul call
}

var TestDim int

func testMatMulExprAxisMismatch(x [2][TestDim]float64, y [2][2]float64) [2][2]float64 {
	return num.MatMul(x, y) // ERROR left argument (shape: [2][TestDim]) not compatible with right argument (shape: [2][2])
}

func testEinsumMissingArguments() [4]float32 {
	a := [4]float32{}
	return num.Einsum(a, []int{1}, []int{}, a) // ERROR wrong number of arguments in call to Einsum
}

func testEinsumInvalidArguments() [1]float32 {
	a := float32(1.0)
	return num.Einsum(a, []int{}, []int{}, a, []int{}, []int{}) // ERROR signature mismatch in call to Einsum
}

func testEinsumContractingDimRange() float32 {
	a := [4]float32{}
	b := [4]float32{}
	return num.Einsum(a, []int{1}, []int{}, b, []int{1}, []int{}) // ERROR axis 1 specified in argument 1 to Einsum is out-of-range: must be in [0, 1)
}

func testEinsumContractingDimUnpaired() [2]float32 {
	a := [4][2]float32{}
	b := [4][2]float32{}
	return num.Einsum(a, []int{1}, []int{}, b, []int{}, []int{}) // ERROR must specify the same number of lhs and rhs contracting dimensions for Einsum (got 1 and 0)
}

func testEinsumContractingDimIncompatible() [2]float32 {
	a := [4][3]float32{}
	b := [4][2]float32{}
	return num.Einsum(a, []int{1}, []int{0}, b, []int{1}, []int{0}) // ERROR left argument (shape: [4][3]) not compatible with right argument (shape: [4][2]) in Einsum call: cannot contract lhs dimension [3] with rhs dimension [2]
}

func testEinsumBatchingDimRange() float32 {
	a := [4]float32{}
	b := [4]float32{}
	return num.Einsum(a, []int{}, []int{1}, b, []int{}, []int{0}) // ERROR axis 1 specified in argument 2 to Einsum is out-of-range: must be in [0, 1)
}

func testEinsumBatchingDimUnpaired() [2]float32 {
	a := [4][2]float32{}
	b := [4][2]float32{}
	return num.Einsum(a, []int{}, []int{0}, b, []int{}, []int{}) // ERROR must specify the same number of lhs and rhs batching dimensions for Einsum (got 1 and 0)
}

func testEinsumBatchingDimIncompatible() [2]float32 {
	a := [4][2]float32{}
	b := [5][2]float32{}
	return num.Einsum(a, []int{1}, []int{0}, b, []int{1}, []int{0}) // ERROR left argument (shape: [4][2]) not compatible with right argument (shape: [5][2]) in Einsum call: cannot batch lhs dimension [4] with rhs dimension [5]
}

func testEinsumDimReused() [2]float32 {
	a := [3][2]float32{}
	b := [3][2]float32{}
	return num.Einsum(a, []int{0}, []int{0}, b, []int{0}, []int{0}) // ERROR axis 0 already specified in argument 2 to Einsum: axes may only be contracted or batched once
}

func testLenMissingArguments() int64 {
	return len() // ERROR incorrect number of arguments for len() (expected 1, found 0)
}

func testLenExtraArguments() int64 {
	return len([1]float32{0}, 100) // ERROR incorrect number of arguments for len([1]float32{0}, 100) (expected 1, found 2)
}

type noLength struct{}

func testLenMismatchedType() int64 {
	return len(noLength{}) // ERROR invalid argument: noLength{} (noLength) for built-in len
}

func testBroadcastIncorrectNumberOfArgument() [4][3]float32 {
	return shape.Broadcast( // ERROR wrong number of arguments
		[]int{4, 3},
		[1][3]float32{{4, 5, 6}},
		false,
	)
}

func testBroadcastIncorrectArgumentType() [4][3]float32 {
	return shape.Broadcast( // ERROR signature mismatch in call to Broadcast
		[]int{4, 3},
		[1][3]float32{{4, 5, 6}},
	)
}

func testBroadcastIncorrectNumberOfAxes() [4][3][6]float32 {
	return shape.Broadcast( // ERROR cannot broadcast array from 2 to 3 axes (expect an equal number)
		[1][3]float32{{4, 5, 6}},
		[]int{4, 3, 6},
	)
}

func testBroadcastIncorrectNumberOfAxisSize() [4][3]float32 {
	return shape.Broadcast( // ERROR cannot broadcast axis 0 from length int(2) to int(4) (expect a source length of 1 or int(4))
		[2][3]float32{
			{1, 2, 3},
			{4, 5, 6},
		},
		[]int{4, 3},
	)
}

func testSplitWithWrongArgCount() [3]float32 {
	return shape.Split([3]float32{1, 2, 3}) // ERROR wrong number of arguments in call to Split
}

func testSplitWithNonDivisibleNumSplits() []float32 {
	return shape.Split(0, [3]float32{1, 2, 3}, 2) // ERROR cannot split axis 0 of length 3 by 2 (expected a remainder of 0, found 1)
}

func testSplitWithIntNumSplit(a int64) []float32 {
	return shape.Split(0, [3]float32{1, 2, 3}, a) // ERROR signature mismatch in call to Split
}

func testSplitWithIntAxisIndex(a int64) []float32 {
	return shape.Split(a, [3]float32{1, 2, 3}, 2) // ERROR signature mismatch in call to Split
}

func testIotaNumArgs() []int64 {
	return num.Iota([]int{2, 3}, 4, 5) // ERROR too many arguments in call to num.Iota (expected 2, found 3)
}

func testIotaArgType() []int64 {
	return num.Iota([]int{2, 3}, [2]int64{1, 2}) // ERROR cannot use type [2]int64 as int in argument to num.Iota
}

func testIotaFull() []int64 {
	return num.IotaFull([]int{2, 3}, 4) // ERROR too many arguments in call to num.IotaFull
}

func testReduceMaxWithMissingAxes() float64 {
	return num.ReduceMax([4]float64{-1, 0, 2, -4}) // ERROR wrong number of arguments in call to ReduceMax
}

func testReduceMaxWithNegativeAxis() float64 {
	return num.ReduceMax([4]float64{-1, 0, 2, -4}, []int{-1}) // ERROR invalid reduction axis in call to ReduceMax: axis -1 does not exist in input [4]float64
}

func testReduceMaxWithInvalidAxis() float64 {
	return num.ReduceMax([4]float64{-1, 0, 2, -4}, []int{1}) // ERROR invalid reduction axis in call to ReduceMax: axis 1 does not exist in input [4]float64
}

func testReduceMaxWithDuplicateAxes() float64 {
	return num.ReduceMax([4]float64{-1, 0, 2, -4}, []int{0, 0}) // ERROR axis index 0 specified more than once
}

func testArgmaxWithMissingAxis() int32 {
	return num.Argmax([...]float32{1, 2, 3}) // ERROR wrong number of arguments in call to Argmax
}

func testArgmaxWithNegativeAxis() int32 {
	return num.Argmax([5]float32{-1, 2, -4, 8, -16}, -1) // ERROR invalid reduction axis in call to Argmax: axis -1 does not exist in input [5]float32
}

func testArgmaxWithInvalidAxis() int32 {
	return num.Argmax([5]float32{-1, 2, -4, 8, -16}, 1) // ERROR invalid reduction axis in call to Argmax: axis 1 does not exist in input [5]float32
}

type loopState struct{}

func testControlWithMissingArg() int32 {
	return control.While(func(x int32) bool { return x < 10 }, func(x int32) int32 { return x + 1 }) // ERROR not enough arguments in call to control.While
}

func testControlWithMismatchedState() loopState {
	s := -0.5
	return control.While(
		s,
		func(s loopState) bool { return false }, // ERROR cannot use type func(s loopState) bool as func(float64) bool in argument to control.While
		func(s loopState) loopState { return loopState{} }, // ERROR cannot use type func(s loopState) loopState as func(float64) float64 in argument to control.While
	)
}

func testControlWithInvalidCondType() loopState {
	return control.While(
		loopState{},
		loopState{}, // ERROR type loopState as func(loopState) bool in argument to control.While
		func(s loopState) loopState { return loopState{} })
}

func testControlWithInvalidCondParameter() loopState {
	return control.While(
		loopState{},
		func(x int32) bool { return false }, // ERROR cannot use type func(x int32) bool as func(loopState) bool in argument to control.While
		func(s loopState) loopState { return loopState{} })
}

func testControlWithInvalidCondResult() loopState {
	return control.While(
		loopState{},
		func(x int32) int32 { return 1 }, // ERROR cannot use type func(x int32) int32 as func(loopState) bool in argument to control.While
		func(s loopState) loopState { return loopState{} })
}

func testControlWithInvalidBodyType() loopState {
	return control.While(
		loopState{},
		func(s loopState) bool { return false },
		loopState{}) // ERROR cannot use type loopState as func(loopState) loopState in argument to control.While
}

func testControlWithInvalidBodyParameter() loopState {
	return control.While(
		loopState{},
		func(x loopState) bool { return false },
		func(s int32) loopState { return loopState{} }) // ERROR cannot use type func(s int32) loopState as func(loopState) loopState in argument to control.While
}

func testControlWithInvalidBodyResult() loopState {
	return control.While(
		loopState{},
		func(x loopState) bool { return false },
		func(s loopState) int32 { return 2 }) // ERROR cannot use type func(s loopState) int32 as func(loopState) loopState in argument to control.While
}

func testMathCeilWithMismatchedShape() [1]float32 {
	return math.Ceil[float32]([2]float32{1, 2}) // ERROR cannot use [2]float32 as [1]float32 value in return statement
}

func testSumWithBool() [1]float32 {
	return num.Sum([2]bool{}, []int{0}) // ERROR expect an array with an algebra data type (found bool)
}

func testRandUint32() int32 {
	rnd := rand.New(rand.NewSource(0))
	var a [1]int32
	_, a = rnd.Uint32([]int{}) // ERROR cannot use uint32 as [1]int32 value in assignment
	return a[0]
}
