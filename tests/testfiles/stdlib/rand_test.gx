var Size intlen

func TestRandUniformFloat32WithSize() [Size]float32 {
	rnd := rand.New(rand.NewSource(0))
	_, a := rnd.Float32[[]intlen{Size}]()
	return a
	// Want:
	// [Size]float32{0.253272, 0.303246}
}

func TestFloat32MinMax() ([5]bool, [5]bool, bool) {
	rnd := rand.New(rand.NewSource(0))
	_, a := rnd.Float32MinMax[[]intlen{5}](-100.5, 100.75)
	return a > -100.5, a < 100.75, num.Sum[[]intidx{0}](math.Abs[float32](a)) > 50
	// Want:
	// 0: [5]bool{true, true, true, true, true}
	// 1: [5]bool{true, true, true, true, true}
	// 2: bool(true)
}

func TestFloat64MinMax() [5]float64 {
	rnd := rand.New(rand.NewSource(0))
	_, a := rnd.Float64MinMax[[]intlen{5}](-100, 100.75)
	return a
	// Want:
	// [5]float64{-39.1233905713, 67.0834894428, -93.5118532834, -38.9040065512, 5.7039784557}
}

const numSamples = 10000

func TestCategorical() bool {
	rnd := rand.New(rand.NewSource(0))
	probs := [1][3]float32{{0.1, 0.2, 0.7}}
	expandedProbs := shape.Broadcast[[]intlen{numSamples, 3}](probs)
	_, labels := rand.Categorical[float32](rnd, expandedProbs)
	numZero := num.Sum[[]intidx{0}]([___]int64(labels == 0))
	numOne := num.Sum[[]intidx{0}]([___]int64(labels == 1))
	numTwo := num.Sum[[]intidx{0}]([___]int64(labels == 2))
	distribution := [3]float32([3]int64{numZero, numOne, numTwo}) / numSamples
	diff := distribution - probs[0]
	return num.ReduceMax[[]intidx{0}](math.Abs(diff)) < 0.01
	// Want:
	// bool(true)
}
