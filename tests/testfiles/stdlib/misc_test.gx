package stdlib

import (
	"math"
	"num"
	"rand"
)

func TestReduceShapeInferenceError() [3]int {
	rnd := rand.New(rand.NewSource(0))
	rnd, samples := rnd.Float32[[]int{3, 2}]()
	return num.ArgMax[1](([3][2]float32)(samples))
	// Want:
	// [3]int{1, 1, 0}
}

func TestLen() int {
	return len(math.Exp([2][1]float32{{1}, {2}}))
	// Want:
	// int(2)
}
