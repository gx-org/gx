package slices

func TestSliceInt32() []int32 {
	return []int32{1, 2}
	// Want:
	// 0: int32(1)
	// 1: int32(2)
}

func TestSliceString() []string {
	return []string{"Hello", "world"}
	// Want:
	// 0: Hello
	// 1: world
}

func TestUnmutable01() ([]string, []string) {
	s1 := []string{"Hello", "world"}
	return s1, append(s1, "Bonjour")
	// Want:
	// 0: Hello
	// 1: world
	// 2: Hello
	// 3: world
	// 4: Bonjour
}

func appendBonjour(s []string) []string {
	s = append(s, "Bonjour")
	return s
}

func TestUnmutable02() ([]string, []string) {
	s1 := []string{"Hello", "world"}
	s2 := appendBonjour(s1)
	return s1, s2
	// Want:
	// 0: Hello
	// 1: world
	// 2: Hello
	// 3: world
	// 4: Bonjour
}

func TestSliceRange01() (string, string, string) {
	s := []string{"a", "b", "c"}
	return s[0], s[1], s[2]
	// Want:
	// 0: a
	// 1: b
	// 2: c
}
