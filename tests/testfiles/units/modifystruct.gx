package modifystruct

type Struct struct {
	A int32
}

func (s Struct) NoOp() {
	s.A = 3
}

func (s Struct) Modify() Struct {
	s.A = 4
	return s
}

func TestModify() Struct {
	a := Struct{A: 2}
	trace(a)
	a.NoOp()
	trace(a)
	a = a.Modify()
	trace(a)
	return a
	// Want:
	// Struct{
	// 	A: int32(4),
	// }
	// Trace:
	// modifystruct.gx:0
	// 	Struct{
	// 		A: int32(2),
	// 	}
	// modifystruct.gx:1
	// 	Struct{
	// 		A: int32(2),
	// 	}
	// modifystruct.gx:2
	// 	Struct{
	// 		A: int32(4),
	// 	}
}
