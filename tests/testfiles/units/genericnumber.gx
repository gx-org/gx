package genericnumber

type (
	ints interface {
		int32 | int64
	}

	floats interface {
		float32 | float64
	}
)

func add[T ints, U floats, S []int](x [unpack(S)]T, y [unpack(S)]U) ([unpack(S)]T, [unpack(S)]U) {
	return x + 2, y + 3
}

func TestAddToAtomics() (int32, float64) {
	return add[int32, float64](5, 7.0)
	// Want:
	// 0: int32(7)
	// 1: float64(10)
}
