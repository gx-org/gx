// Package varargs tests passing a variable number of arguments to a function.
package varargs

import "num"

func iota[lens []intlen]() [unpack(lens)]int64 {
	return num.IotaFull[lens]()
}

func Test0() any {
	return iota[[]intlen{}]()
	// Want:
	// [lens]int64(0)
}

func Test1() [2]int64 {
	return iota[[]intlen{2}]()
	// Want:
	// [lens]int64{0, 1}
}

func Test3() [2][3]int64 {
	return iota[[]intlen{2, 3}]()
	// Want:
	// [lens]int64{
	// 	{0, 1, 2},
	// 	{3, 4, 5},
	// }
}
