package genericshapes

import (
	"dtype"
	"num"
)

func traceGenericShapes[T dtype.Num, A, B int, S []int](a [A][B]T, b [unpack(S)]T) [A][B]int64 {
	trace(A)
	trace(B)
	trace(S)
	return num.IotaFull[[]int{A, B}]()
}

func TestTraceGenericShapes() [2][3]int64 {
	return traceGenericShapes(
		[2][3]float32{},
		[4][5][6]float32{},
	)
	// Want:
	// [2][3]int64{
	// 	{0, 1, 2},
	// 	{3, 4, 5},
	// }
	// Trace:
	// genericshapes.gx:0
	// 	int(2)
	// genericshapes.gx:1
	// 	int(3)
	// genericshapes.gx:2
	// 	[int(4),int(5),int(6)]
}
