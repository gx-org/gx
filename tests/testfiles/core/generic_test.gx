package core

type floats interface {
	bfloat16 | float32 | float64
}

func genericCast[T floats](x [2]float32) [2]T {
	return [2]T(x)
}

func TestGenericCast() [2]float64 {
	return genericCast[float64]([2]float32{1, 2})
	// Want:
	// [2]float64{1, 2}
}

func callGenericCast[T floats](x [2]float32) [2]T {
	return genericCast[T](x)
}

func TestGenericCallGenericCast() [2]float64 {
	return callGenericCast[float64]([2]float32{1, 2})
	// Want:
	// [2]float64{1, 2}
}

func newFloat32(shape []intlen) [shape___]float32 {
	return [shape___]float32{}
}

func genericNewFloat32[T floats](shape []intlen) [shape___]T {
	return [shape___]T(newFloat32(shape))
}

func TestGenericCastWithGenericShape() [2][3]float64 {
	return genericNewFloat32[float64]([]intlen{2, 3})
	// Want:
	// [2][3]float64{
	// 	{0, 0, 0},
	// 	{0, 0, 0},
	// }
}
