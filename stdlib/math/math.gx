// Sign returns the sign of x.
func Sign[T dtype.Num]([___S]T) [S___]T

// Sin returns the sine of x.
// gx:@grad.Set(Cos)
func Sin[T dtype.Num]([___S]T) [S___]T

// Sqrt returns sqrt(x).
func Sqrt[T dtype.Num]([___S]T) [S___]T

// Tanh returns the hyperbolic tangent of x.
