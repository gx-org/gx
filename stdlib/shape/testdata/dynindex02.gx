package dynindex02

import "num"

func TestDyanmicIndex3Axis() [][2][4]int64 {
	indices := num.IotaFull[[]intlen{3}]()
	a := num.IotaFull[[]intlen{3, 2, 4}]()
	return [][2][4]int64{
		a[indices[0]], a[indices[1]], a[indices[2]],
	}
	// Want:
	// 0: [2][4]int64{
	// 	{0, 1, 2, 3},
	// 	{4, 5, 6, 7},
	// }
	// 1: [2][4]int64{
	// 	{8, 9, 10, 11},
	// 	{12, 13, 14, 15},
	// }
	// 2: [2][4]int64{
	// 	{16, 17, 18, 19},
	// 	{20, 21, 22, 23},
	// }
}
